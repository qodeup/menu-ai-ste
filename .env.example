# Static mode (default): leave these empty and place your menu in public/menu.json
VITE_MONOLITH_BASE_URL=
VITE_BUSINESS_ID=
VITE_MENU_ID=0

# Monolith mode: set VITE_MONOLITH_BASE_URL and VITE_BUSINESS_ID to enable live API fetching.
# The app will call:
#   GET {VITE_MONOLITH_BASE_URL}/businesses/{VITE_BUSINESS_ID}/menu/{lang}?menu={VITE_MENU_ID}&group_by=type
#   GET {VITE_MONOLITH_BASE_URL}/businesses/{VITE_BUSINESS_ID}/section/{sectionId}/{lang}?menu={VITE_MENU_ID}
#
# Example:
# VITE_MONOLITH_BASE_URL=https://api.qodeup.com
# VITE_BUSINESS_ID=your-business-uuid
# VITE_MENU_ID=0
